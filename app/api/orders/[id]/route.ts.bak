import { NextResponse } from 'next/server';
import { getServerSession } from 'next-auth';
import { prisma } from '@/lib/prisma';
import { authOptions } from '../../auth/[...nextauth]/route';

// 특정 주문 조회 API
export async function GET(req: Request, { params }: { params: { id: string } }) {
  try {
    // 세션 정보 확인
    const session = await getServerSession(authOptions);
    console.log('주문 상세 조회 - 세션 정보:', JSON.stringify(session, null, 2));

    // 인증 확인
    if (!session || !session.user) {
      console.log('주문 상세 조회 - 인증 실패');
      return NextResponse.json(
        { error: '인증이 필요합니다.' },
        { status: 401 }
      );
    }

       const { id } = params;
   const orderId = id;
    console.log('주문 상세 조회 - 주문 ID:', orderId);

    // 주문 정보 조회
    const order = await prisma.order.findUnique({
      where: { id: orderId },
      include: {
        orderItems: true,
        user: {
          select: {
            name: true,
            branchName: true,
          },
        },
      },
    });

    if (!order) {
      console.log('주문 상세 조회 - 주문 없음:', orderId);
      return NextResponse.json(
        { error: '주문을 찾을 수 없습니다.' },
        { status: 404 }
      );
    }

    // 지점 사용자인 경우 자신의 주문만 조회 가능
    if (
      session.user.role === 'BRANCH' &&
      order.userId !== session.user.id
    ) {
      console.log('주문 상세 조회 - 권한 없음:', {
        orderUserId: order.userId,
        requestUserId: session.user.id,
      });
      return NextResponse.json(
        { error: '이 주문에 접근할 권한이 없습니다.' },
        { status: 403 }
      );
    }

    console.log('주문 상세 조회 - 성공:', orderId);

    // 응답 데이터 구성
    return NextResponse.json({
      success: true,
      order: order,
    });
  } catch (error) {
    console.error('주문 상세 조회 오류:', error);
    return NextResponse.json(
      { error: '주문 정보를 조회하는 중 오류가 발생했습니다.' },
      { status: 500 }
    );
  }
}

// 주문 수정 API
export async function PUT(req: Request, { params }: { params: { id: string } }) {
  try {
    // 세션 정보 확인
    const session = await getServerSession(authOptions);
    console.log('주문 수정 - 세션 정보:', JSON.stringify(session, null, 2));

    // 인증 확인
    if (!session || !session.user) {
      console.log('주문 수정 - 인증 실패');
      return NextResponse.json(
        { error: '인증이 필요합니다.', action: 'relogin' },
        { status: 401 }
      );
    }

    // 사용자 존재 여부 확인
    const user = await prisma.user.findUnique({
      where: { id: session.user.id },
    });

    if (!user) {
      console.log('주문 수정 - 데이터베이스에 사용자 없음:', session.user.id);
      return NextResponse.json(
        { 
          error: '사용자 정보를 찾을 수 없습니다.',
          action: 'relogin'
        },
        { status: 401 }
      );
    }

       const { id } = params;
   const orderId = id;
    console.log('주문 수정 - 주문 ID:', orderId);

    // 주문 존재 여부 확인
    const existingOrder = await prisma.order.findUnique({
      where: { id: orderId },
      include: { orderItems: true },
    });

    if (!existingOrder) {
      console.log('주문 수정 - 주문 없음:', orderId);
      return NextResponse.json(
        { error: '주문을 찾을 수 없습니다.' },
        { status: 404 }
      );
    }

    // 지점 사용자인 경우 자신의 주문만 수정 가능
    if (
      session.user.role === 'BRANCH' &&
      existingOrder.userId !== session.user.id
    ) {
      console.log('주문 수정 - 권한 없음:', {
        orderUserId: existingOrder.userId,
        requestUserId: session.user.id,
      });
      return NextResponse.json(
        { error: '이 주문을 수정할 권한이 없습니다.' },
        { status: 403 }
      );
    }

    // 주문 상태 확인 - 완료 또는 취소된 주문은 수정 불가
    if (['DELIVERED'].includes(existingOrder.status)) {
      console.log('주문 수정 - 수정 불가 상태:', existingOrder.status);
      return NextResponse.json(
        { error: `배송 완료된 주문은 수정할 수 없습니다.` },
        { status: 400 }
      );
    }

    // 요청 본문 파싱
    const requestData = await req.json();
    console.log('주문 수정 - 요청 데이터:', JSON.stringify(requestData, null, 2));

    const {
      deliveryDate,
      arrivalTime,
      destination,
      address,
      phoneNumber,
      memo,
      items // 항목 배열
    } = requestData;

    // 필수 필드 검증
    if (!deliveryDate || !destination || !address || !phoneNumber) {
      console.log('주문 수정 - 필수 필드 누락');
      return NextResponse.json(
        { error: '납품일자, 하차지, 주소, 전화번호는 필수 입력 항목입니다.' },
        { status: 400 }
      );
    }

    // 항목 검증
    if (!items || !Array.isArray(items) || items.length === 0) {
      console.log('주문 수정 - 항목 없음');
      return NextResponse.json(
        { error: '최소 하나의 주문 항목이 필요합니다.' },
        { status: 400 }
      );
    }

    // 유효하지 않은 품목 체크
    for (const item of items) {
      if (!item.itemName || item.quantity < 1) {
        console.log('주문 수정 - 유효하지 않은 항목:', item);
        return NextResponse.json(
          { error: '모든 주문 항목에 유효한 품목명과 수량이 필요합니다.' },
          { status: 400 }
        );
      }
    }

    // 주문 수정 트랜잭션
    const updatedOrder = await prisma.$transaction(async (tx) => {
      // 기존 주문 항목 삭제
      await tx.orderItem.deleteMany({
        where: { orderId: orderId },
      });

      // 주문 업데이트
      const updated = await tx.order.update({
        where: { id: orderId },
        data: {
          deliveryDate: new Date(deliveryDate),
          arrivalTime,
          destination,
          address,
          phoneNumber,
          memo,
          orderItems: {
            create: items.map((item: any) => ({
              itemName: item.itemName,
              quantity: Number(item.quantity)
            }))
          },
          updatedAt: new Date()
        },
        include: {
          orderItems: true,
          user: {
            select: {
              name: true,
              branchName: true
            }
          }
        }
      });

      return updated;
    });

    console.log('주문 수정 성공:', orderId);

    // 응답 데이터 구성
    return NextResponse.json({
      success: true,
      message: '주문이 성공적으로 수정되었습니다.',
      order: updatedOrder
    });
  } catch (error) {
    console.error('주문 수정 오류:', error);
    return NextResponse.json(
      { 
        error: '주문을 수정하는 중 오류가 발생했습니다.',
        details: (error as Error).message 
      },
      { status: 500 }
    );
  }
}

// 주문 삭제 API
export async function DELETE(req: Request, { params }: { params: { id: string } }) {
  try {
    // 세션 정보 확인
    const session = await getServerSession(authOptions);
    console.log('주문 삭제 - 세션 정보:', JSON.stringify(session, null, 2));

    // 인증 확인
    if (!session || !session.user) {
      console.log('주문 삭제 - 인증 실패');
      return NextResponse.json(
        { error: '인증이 필요합니다.', action: 'relogin' },
        { status: 401 }
      );
    }
   const { id } = params;
   const orderId = id;
    console.log('주문 삭제 - 주문 ID:', orderId);

    // 주문 존재 여부 확인
    const existingOrder = await prisma.order.findUnique({
      where: { id: orderId },
    });

    if (!existingOrder) {
      console.log('주문 삭제 - 주문 없음:', orderId);
      return NextResponse.json(
        { error: '주문을 찾을 수 없습니다.' },
        { status: 404 }
      );
    }

    // 권한 확인 - 관리자 또는 자신의 주문만 삭제 가능
    if (
      session.user.role === 'BRANCH' &&
      existingOrder.userId !== session.user.id
    ) {
      console.log('주문 삭제 - 권한 없음:', {
        orderUserId: existingOrder.userId,
        requestUserId: session.user.id,
      });
      return NextResponse.json(
        { error: '이 주문을 삭제할 권한이 없습니다.' },
        { status: 403 }
      );
    }

    // 주문 상태 확인 - 완료된 주문은 삭제 불가
    if (existingOrder.status === 'DELIVERED') {
      console.log('주문 삭제 - 삭제 불가 상태:', existingOrder.status);
      return NextResponse.json(
        { error: '배송 완료된 주문은 삭제할 수 없습니다.' },
        { status: 400 }
      );
    }

    // 주문 삭제 트랜잭션
    await prisma.$transaction(async (tx) => {
      // 주문 항목 삭제
      await tx.orderItem.deleteMany({
        where: { orderId },
      });

      // 주문 삭제
      await tx.order.delete({
        where: { id: orderId },
      });
    });

    console.log('주문 삭제 성공:', orderId);

    // 응답 데이터 구성
    return NextResponse.json({
      success: true,
      message: '주문이 성공적으로 삭제되었습니다.'
    });
  } catch (error) {
    console.error('주문 삭제 오류:', error);
    return NextResponse.json(
      { error: '주문을 삭제하는 중 오류가 발생했습니다.' },
      { status: 500 }
    );
  }
}

