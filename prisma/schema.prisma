generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(BRANCH)
  branchName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

enum Role {
  ADMIN
  BRANCH
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  deliveryDate DateTime
  arrivalTime  String
  destination  String
  address      String
  phoneNumber  String
  status       OrderStatus @default(RECEIVED)
  memo         String?
  isWingCarRestricted Boolean @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
}

enum OrderStatus {
  RECEIVED      // 주문접수
  DISPATCHED    // 차량배차
  DELIVERED     // 배송완료
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemName  String   // 품목
  quantity  Int      // 수량
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
